<h1>test</h1>


<div class="row mt-4">
    <div class="col-lg-12 text-center">
        <h3>Shopping List</h3>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th scope="col">No.</th>
                <th scope="col">Name</th>
                <th scope="col">Price</th>
                <th scope="col">Quantity</th>
                <th scope="col">Date</th>
                <th scope="col">Status</th>
                <th scope="col" colspan="2">Action</th>
            </tr>
        </thead>
        <tbody>
            {{#each Shoplist}}
            <tr>

                <td>#</td>
                <td>{{this.name}}</td>
                <td>{{this.price}}</td>
                <td>{{this.qty}}</td>
                <td>{{this.date}}</td>
                <td>{{this.Status}}</td> 
                <td>
                    <a href="/editData/{{this._id}}" class="btn btn-info btn-sm">Edit</a>
                    
                    <form action="/delete/{{this._id}}?_method=DELETE" method="POST" style="display: inline;">
                        <button class="btn btn-warning btn-sm">Delete</button>
                    </form>

                </td>
                {{/each}}
            </tr>
        </tbody>
    </table>
</div>