<div class="row mt-4">
    <div class="col-lg-12 col-md-6 col-sm-4">
        <h3 class="text-center">Edit Shopping List</h3>
        <form method="POST" action="/editData/{{Shoplist._id}}?_method=PUT">
            <div class="mb-3">
                <label for="name" class="form-label">Items</label>
                <input type="text" class="form-control" id="item" name="name" value="{{Shoplist.name}}">
            </div>
            <div class="mb-3">
                <label for="price" class="form-label">Price</label>
                <input type="number" class="form-control" id="price" name="price" value="{{Shoplist.price}}">
            </div>
            <div class="mb-3">
                <label for="qty" class="form-label">Quantity</label>
                <input type="number" class="form-control" id="qty" name="qty" value="{{Shoplist.qty}}">
            </div>
            <button type="submit" class="btn btn-primary">Submit</button>
        </form>
    </div>
</div>